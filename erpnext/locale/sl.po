"        </li>\n"
"        <li>\n"
"            <code>{{ supplier_name }}</code>: Ime podjetja vašega dobavitelja.\n"
"        </li>\n"
"        <li>\n"
"            <code>{{ contact.salutation }} {{ contact.last_name }}</code>: Kontaktna oseba vašega dobavitelja.\n"
"        </li><li>\n"
"            <code>{{ user_fullname }}</code>: Vaše polno ime.\n"
"        </li>\n"
"    </ul>\n"
"<p></p>\n"
